[Unit]
Description=Recorder admin web (Flask + gunicorn)
After=network.target

[Service]
Type=simple
User=ftadmin
WorkingDirectory=/opt/recorder/web
Environment="RECORDINGS_DIR=/opt/recorder/recordings"
Environment="SRS_PORT=8080"
Environment="STREAM_MAIN=recorder-main"
Environment="STREAM_AUX=recorder-aux"
Environment="SESSION_TIMEOUT_MIN=30"
# --timeout 300: LLM endpoints (transcript/refine, summary) call out to
#   external LLM APIs that routinely take 60-180s on long meetings.
#   Default gunicorn worker timeout is 30s — it kills the worker mid-call
#   and the browser sees "Failed to fetch".
# --graceful-timeout 30: on systemctl reload, still let workers drain in 30s.
ExecStart=/usr/bin/python3 -m gunicorn --workers 2 --threads 4 --timeout 300 --graceful-timeout 30 --bind 0.0.0.0:8088 --access-logfile - --error-logfile - app:app
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
