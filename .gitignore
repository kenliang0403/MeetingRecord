# 编译产物
build/
bin/
*.obj
*.o
*.lib
*.dll
*.a
*.exe
*.pdb

# Python 字节码
__pycache__/
*.pyc

# 运行产生的日志和媒体文件
logs/
recordings/
*.log
*.pcap
*.pcapng

# IDE和系统文件
.vs/
.vscode/
*.user
*.suo
.DS_Store
Thumbs.db

# 本地环境配置文件（敏感信息）
.env

# 内部部署脚本（含具体服务器信息 / 私人开发机路径，不公开）
# 注意：目录名必须是 ASCII —— 中文路径会让 Windows OpenSSH 的
# SSH_ASKPASS 子进程 spawn 失败（CreateProcessW error:2）。
deploy-private/

# Claude / 临时
.claude/
cap/

# SSH on bash creates a real file named NUL when scripts intended for
# Windows powershell run under WSL/git-bash (UserKnownHostsFile=NUL).
NUL
