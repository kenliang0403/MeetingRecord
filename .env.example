# Recorder deployment env
# Copy this to .env (gitignored) and fill in your values.
#
# Used by scripts/load_env.ps1 (PowerShell) and scripts/load_env.sh (bash).
# All scripts/*.ps1 and scripts/*.sh source one of these before doing ssh/scp.

# --- Required for any deploy ---

# Hostname / IP of your recorder server (where recorder-core + web run).
# Example: 10.0.0.10 or recorder.example.com
RECORDER_HOST=

# Username on the recorder host (ssh + sudo user).
# Defaults to ftadmin in our reference setup.
RECORDER_USER=ftadmin

# Password used by ssh / scp / sudo -S.
# Strongly prefer SSH key auth in production — only set this when adding
# keys to the server is impractical (e.g. running scripts from Windows
# powershell without an agent).
RECORDER_SSH_PASSWORD=

# --- Optional ---

# Secondary recorder host (HA / failover). Defaults to RECORDER_HOST.
# Used by scripts/upload_build.ps1 when called with `-Secondary`.
RECORDER_HOST_SECONDARY=

# --- Legacy compatibility (will be removed in future versions) ---
# Old scripts used RECORDER_102_PASSWORD. askpass.cmd/.sh still accept it
# but it's deprecated — set RECORDER_SSH_PASSWORD above instead.
# RECORDER_102_PASSWORD=
