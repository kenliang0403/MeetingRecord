# Recorder deployment env (Windows 包装脚本用)
# Copy this to .env (gitignored) and fill in your values.
#
# 公开仓库本身**不带** PowerShell 包装脚本（含私人主机/账号信息）。
# 如果你照着 scripts/README.md 自己写 .ps1 包装从 Windows 本机一键
# 部署到远程服务器，把变量填到 .env 里 — 你的脚本读 .env 而不是
# 把主机名/密码硬编进代码。
#
# 直接 ssh 上服务器手动跑 scripts/install_web.sh 不需要 .env。

# Hostname / IP of your recorder server.
# Example: 10.0.0.10 or recorder.example.com
RECORDER_HOST=

# Username on the recorder host (ssh + sudo user).
RECORDER_USER=ftadmin

# Password for ssh / scp / sudo -S. 强烈建议生产环境用 SSH 公钥认证，
# 只有在不方便配 key 时（如 Windows 没 ssh-agent）才在这里填密码。
RECORDER_SSH_PASSWORD=

# Secondary recorder host (HA / failover). 可空。
RECORDER_HOST_SECONDARY=
